# ============================================================================
# ZV TASK MANAGER · VARIABLES DE ENTORNO (plantilla de referencia)
# ============================================================================
# Este proyecto es 100% estático (HTML/CSS/JS) para GitHub Pages, por lo que
# las credenciales de Supabase se configuran directamente en
# assets/js/config.js (son seguras de exponer porque son la "anon key").
#
# Este archivo .env.example es solo documentación de qué valores necesitas
# y dónde obtenerlos. NO es leído automáticamente por el sistema.
# ============================================================================

# URL de tu proyecto Supabase (Project Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública "anon" (Project Settings > API > anon public)
# Segura para frontend público SIEMPRE que tengas RLS activo en todas las tablas.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave "service_role" (Project Settings > API > service_role)
# ⚠️ NUNCA la uses en el frontend ni la subas a un repositorio público.
# Solo se usa en scripts administrativos locales o backend seguro.
SUPABASE_SERVICE_ROLE_KEY=

# Nombre del bucket de Supabase Storage para fotos de perfil (crear manualmente)
SUPABASE_STORAGE_BUCKET_AVATARES=avatares
